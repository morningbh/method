# Method — local environment variables
# NEVER commit the real .env into git (.gitignore must include .env)
# Copy this file to .env and fill in real values.

# Admin / identity
ADMIN_EMAIL=REPLACE_ME

# SMTP (Gmail app password recommended)
SMTP_HOST=REPLACE_ME
SMTP_PORT=REPLACE_ME
SMTP_USER=REPLACE_ME
SMTP_PASSWORD=REPLACE_ME
SMTP_FROM=REPLACE_ME
SMTP_FROM_NAME=REPLACE_ME

# Public base URL (used for approval / login links)
BASE_URL=REPLACE_ME

# Claude CLI
CLAUDE_BIN=REPLACE_ME
CLAUDE_MODEL=REPLACE_ME
CLAUDE_TIMEOUT_SEC=REPLACE_ME
CLAUDE_CONCURRENCY=REPLACE_ME

# Paths
DB_PATH=REPLACE_ME
UPLOAD_DIR=REPLACE_ME
PLAN_DIR=REPLACE_ME
LOG_DIR=REPLACE_ME

# Auth / sessions
SESSION_SECRET=REPLACE_ME
SESSION_TTL_DAYS=REPLACE_ME
LOGIN_CODE_TTL_MIN=REPLACE_ME
APPROVAL_TOKEN_TTL_DAYS=REPLACE_ME

# E2E tests — a second mailbox used for the non-admin approval flow
E2E_TEST_USER_EMAIL=REPLACE_ME
